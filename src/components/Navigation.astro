---
// Navigation - working mobile menu + scroll glassmorphism
import Container from '@/components/Container.astro';
import { SITE } from '@/config/site';

export interface Props {
  logo?: string;
}

const { logo = SITE.name } = Astro.props;
---

<header id="navbar" class="sticky top-0 z-40 bg-background backdrop-blur-lg" data-ps="src/components/Navigation.astro:dt8k87">
  <nav class="py-4" data-ps="src/components/Navigation.astro:m59h3b">
    <Container class="flex justify-between items-center">
      <a href="/" class="text-3xl font-black text-foreground no-underline hover:text-primary transition-colors tracking-tighter" data-ps="src/components/Navigation.astro:kd8n5y">
        SPEOC
      </a>

      <div class="flex items-center gap-6" data-ps="src/components/Navigation.astro:gqvsdc">
        <div class="hidden md:flex gap-10 items-center" data-ps="src/components/Navigation.astro:gqvsdd">
          <a href="/#solutions" class="text-sm font-bold uppercase tracking-widest text-foreground hover:text-primary transition-colors" data-ps="src/components/Navigation.astro:kd8n5y">Practice Areas</a>
          <a href="/#accolades" class="text-sm font-bold uppercase tracking-widest text-foreground hover:text-primary transition-colors" data-ps="src/components/Navigation.astro:kd8n5w">Industry Leadership</a>
          <a href="/#contact" class="px-5 py-2.5 border border-secondary text-sm font-bold uppercase tracking-widest text-secondary hover:bg-secondary hover:text-secondary-foreground transition-all" data-ps="src/components/Navigation.astro:kd8n5v">
            Contact Advisory
          </a>
        </div>

        <button
          id="mobile-menu-button"
          type="button"
          class="md:hidden p-2 text-foreground hover:text-primary transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
         data-ps="src/components/Navigation.astro:5ds1">
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </Container>
  </nav>

  <div
    id="mobile-menu"
    class="hidden md:hidden overflow-hidden bg-background border-t border-border"
    role="navigation"
    aria-label="Mobile navigation"
   data-ps="src/components/Navigation.astro:gqvsde">
    <nav class="flex flex-col py-6 px-6 gap-4" data-ps="src/components/Navigation.astro:m59h3a">
      <a href="/#solutions" class="text-sm font-bold uppercase tracking-widest text-foreground py-2" data-ps="src/components/Navigation.astro:kd8n5u">Practice Areas</a>
      <a href="/#accolades" class="text-sm font-bold uppercase tracking-widest text-foreground py-2" data-ps="src/components/Navigation.astro:kd8n5s">Client Engagements</a>
      <a href="/#contact" class="inline-block mt-4 px-6 py-3 bg-secondary text-secondary-foreground text-sm font-bold uppercase tracking-widest text-center" data-ps="src/components/Navigation.astro:kd8n5r">
        Contact Advisory
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  const navbar = document.getElementById('navbar');
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  // On scroll, add bg-{color}/90 for desktop glassmorphism
  // IMPORTANT: must match the header bg-* class above (e.g. bg-background -> md:bg-background/90)
  function updateNavbar() {
    if (window.scrollY > 50) {
      navbar?.classList.add('md:bg-background/90');
    } else {
      navbar?.classList.remove('md:bg-background/90');
    }
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  function toggleMenu() {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      menuIconOpen?.classList.remove('hidden');
      menuIconClose?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
    } else {
      mobileMenu?.classList.remove('hidden');
      menuIconOpen?.classList.add('hidden');
      menuIconClose?.classList.remove('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'true');
    }
  }

  mobileMenuButton?.addEventListener('click', toggleMenu);
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuIconOpen?.classList.remove('hidden');
      menuIconClose?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
      toggleMenu();
    }
  });
</script>
