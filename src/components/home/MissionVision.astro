---
import Container from '@/components/Container.astro';
---

<section id="mission" class="bg-dark-background text-dark-foreground overflow-hidden" data-ps="src/components/home/MissionVision.astro:bzx5lv">
  <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[600px]" data-ps="src/components/home/MissionVision.astro:wnc7kc">
    <!-- Mission -->
    <div class="relative py-24 px-4 md:px-8 lg:px-12 flex flex-col justify-center border-b lg:border-b-0 lg:border-r border-dark-border reveal" data-ps="src/components/home/MissionVision.astro:wnc7kd">
      <div class="max-w-xl mx-auto" data-ps="src/components/home/MissionVision.astro:wnc7ke">
        <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-4" data-ps="src/components/home/MissionVision.astro:abx41e">The Mission</span>
        <h2 class="text-h2 font-bold mb-8" data-ps="src/components/home/MissionVision.astro:dgzna">Transforming Risk into Opportunity.</h2>
        <p class="text-lg text-dark-muted-foreground leading-relaxed mb-12" data-ps="src/components/home/MissionVision.astro:fh2u6y">
          To deliver strategic consulting and advanced security solutions that transform risk into opportunity, strengthen digital resilience, and enable sustainable, confident growth for the global enterprise.
        </p>
        <div class="relative aspect-video overflow-hidden rounded-sm border border-dark-border" data-ps="src/components/home/MissionVision.astro:wnc7kf">
          <img 
            src="https://images.pexels.com/photos/5380618/pexels-photo-5380618.jpeg?auto=compress&cs=tinysrgb&w=1200" 
            srcset="https://images.pexels.com/photos/5380618/pexels-photo-5380618.jpeg?auto=compress&cs=tinysrgb&w=320 320w, https://images.pexels.com/photos/5380618/pexels-photo-5380618.jpeg?auto=compress&cs=tinysrgb&w=480 480w, https://images.pexels.com/photos/5380618/pexels-photo-5380618.jpeg?auto=compress&cs=tinysrgb&w=640 640w, https://images.pexels.com/photos/5380618/pexels-photo-5380618.jpeg?auto=compress&cs=tinysrgb&w=768 768w, https://images.pexels.com/photos/5380618/pexels-photo-5380618.jpeg?auto=compress&cs=tinysrgb&w=1024 1024w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="Modern cyber security operations center" 
            class="h-full w-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
            loading="lazy" data-ps="src/components/home/MissionVision.astro:2s38x1" />
        </div>
      </div>
    </div>

    <!-- Vision -->
    <div class="relative py-24 px-4 md:px-8 lg:px-12 flex flex-col justify-center reveal reveal-delay-1" data-ps="src/components/home/MissionVision.astro:wnc7kg">
      <div class="max-w-xl mx-auto" data-ps="src/components/home/MissionVision.astro:wnc7kh">
        <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-4" data-ps="src/components/home/MissionVision.astro:abx41f">The Vision</span>
        <h2 class="text-h2 font-bold mb-8" data-ps="src/components/home/MissionVision.astro:dgznb">A Future Engineered for Confidence.</h2>
        <p class="text-lg text-dark-muted-foreground leading-relaxed mb-12" data-ps="src/components/home/MissionVision.astro:fh2u6z">
          To be the globally recognised and trusted partner that empowers organisations to advance with confidence — where every step is secure, and every ambition protected by design.
        </p>
        <div class="relative aspect-video overflow-hidden rounded-sm border border-dark-border" data-ps="src/components/home/MissionVision.astro:wnc7ki">
          <img 
            src="https://images.pexels.com/photos/5408005/pexels-photo-5408005.jpeg?auto=compress&cs=tinysrgb&w=1200" 
            srcset="https://images.pexels.com/photos/5408005/pexels-photo-5408005.jpeg?auto=compress&cs=tinysrgb&w=320 320w, https://images.pexels.com/photos/5408005/pexels-photo-5408005.jpeg?auto=compress&cs=tinysrgb&w=480 480w, https://images.pexels.com/photos/5408005/pexels-photo-5408005.jpeg?auto=compress&cs=tinysrgb&w=640 640w, https://images.pexels.com/photos/5408005/pexels-photo-5408005.jpeg?auto=compress&cs=tinysrgb&w=768 768w, https://images.pexels.com/photos/5408005/pexels-photo-5408005.jpeg?auto=compress&cs=tinysrgb&w=1024 1024w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="Technical server infrastructure advisory" 
            class="h-full w-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
            loading="lazy" data-ps="src/components/home/MissionVision.astro:2s38x2" />
        </div>
      </div>
    </div>
  </div>
</section>
