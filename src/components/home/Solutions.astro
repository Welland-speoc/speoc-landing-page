---
import Container from '@/components/Container.astro';
---

<section id="solutions" class="py-24 bg-surface border-t border-b border-border" data-ps="src/components/home/Solutions.astro:k4tix9">
  <Container>
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8" data-ps="src/components/home/Solutions.astro:s0dxrx">
      <div class="max-w-2xl reveal" data-ps="src/components/home/Solutions.astro:s0dxrw">
        <h2 class="text-h2 font-bold text-foreground mb-4" data-ps="src/components/home/Solutions.astro:hmdsuc">Strategic Pillars</h2>
        <p class="text-lg text-muted-foreground" data-ps="src/components/home/Solutions.astro:ja7n51">Practice areas engineered for absolute operational resilience and governance excellence.</p>
      </div>
      <div class="reveal reveal-delay-1" data-ps="src/components/home/Solutions.astro:s0dxrv">
        <a href="#contact" class="text-sm font-bold uppercase tracking-widest text-primary border-b-2 border-primary pb-1 hover:text-primary-hover hover:border-primary-hover transition-colors" data-ps="src/components/home/Solutions.astro:c69qf8"></a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 border border-border bg-background" data-ps="src/components/home/Solutions.astro:s0dxru">
      <!-- Card 1 -->
      <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-border hover:bg-surface transition-colors group reveal" data-ps="src/components/home/Solutions.astro:s0dxrt">
        <div class="h-12 w-12 bg-primary/5 rounded-sm flex items-center justify-center mb-8 group-hover:bg-primary/10 transition-colors" data-ps="src/components/home/Solutions.astro:s0dxrs">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold mb-4" data-ps="src/components/home/Solutions.astro:wasq1z">Strategic Cybersecurity</h3>
        <p class="text-muted-foreground leading-relaxed" data-ps="src/components/home/Solutions.astro:ja7n50">Governance mapping, advanced posture assessment, and secure enterprise architecture designed for long-term resilience.</p>
      </div>

      <!-- Card 2 -->
      <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-border hover:bg-surface transition-colors group reveal reveal-delay-1" data-ps="src/components/home/Solutions.astro:s0dxrr">
        <div class="h-12 w-12 bg-primary/5 rounded-sm flex items-center justify-center mb-8 group-hover:bg-primary/10 transition-colors" data-ps="src/components/home/Solutions.astro:s0dxrq">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold mb-4" data-ps="src/components/home/Solutions.astro:wasq1y">Privacy Engineering</h3>
        <p class="text-muted-foreground leading-relaxed" data-ps="src/components/home/Solutions.astro:ja7n4z">Structural regulatory alignment (GDPR, PIPL, PDPO) engineered for frictionless product scaling and trusted customer relationships.</p>
      </div>

      <!-- Card 3 -->
      <div class="p-8 md:p-12 hover:bg-surface transition-colors group reveal reveal-delay-2" data-ps="src/components/home/Solutions.astro:s0dxrp">
        <div class="h-12 w-12 bg-primary/5 rounded-sm flex items-center justify-center mb-8 group-hover:bg-primary/10 transition-colors" data-ps="src/components/home/Solutions.astro:s0dxro">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold mb-4" data-ps="src/components/home/Solutions.astro:wasq1x">Emerging Tech Advisory</h3>
        <p class="text-muted-foreground leading-relaxed" data-ps="src/components/home/Solutions.astro:ja7n4y">Secure integration of artificial intelligence, post-quantum cryptography (PQC), and automated risk systems into legacy corporate frameworks.</p>
      </div>
    </div>
  </Container>
</section>
