---
import Container from '@/components/Container.astro';
---

<section id="purpose" class="py-24 md:py-32 bg-background border-t border-border overflow-hidden" data-ps="src/components/home/Purpose.astro:b2hgnx">
  <Container>
    <div class="max-w-4xl mx-auto text-center reveal" data-ps="src/components/home/Purpose.astro:k4j3y2">
      <div class="inline-flex items-center gap-2 mb-6 justify-center" data-ps="src/components/home/Purpose.astro:k4j3y1">
        <span class="text-xs font-bold tracking-[0.3em] uppercase text-muted-foreground" data-ps="src/components/home/Purpose.astro:rx7bu2">Foundational Ethos</span>
      </div>
      
      <h2 class="text-h2 font-bold tracking-tight text-foreground mb-12" data-ps="src/components/home/Purpose.astro:n8mxnw">
        To Thrive in a Complex World
      </h2>
      
      <div class="grid-border pt-12" data-ps="src/components/home/Purpose.astro:k4j3y0">
        <p class="text-xl md:text-2xl text-muted-foreground leading-relaxed max-w-3xl mx-auto italic font-light" data-ps="src/components/home/Purpose.astro:1kozzv">
          "Our Purpose is to empower organisations with the security, privacy, clarity, and confidence they need to navigate a rapidly evolving digital landscape. We build resilient frameworks that turn operational risk into sustainable growth."
        </p>
      </div>
    </div>
  </Container>
</section>
