---
import Container from '@/components/Container.astro';
---

<section id="hero" class="relative overflow-hidden bg-background pt-[var(--nav-height)] pb-12 md:pb-24" data-ps="src/components/home/Hero.astro:c630g">
  <Container class="relative z-10">
    <div class="flex flex-col items-center text-center" data-ps="src/components/home/Hero.astro:iy4tag">
      <!-- Text Block -->
      <div class="w-full max-w-4xl py-12 md:py-20 flex flex-col items-center justify-center" data-ps="src/components/home/Hero.astro:iy4tah">
        <div class="inline-flex items-center gap-2 mb-8 reveal" data-ps="src/components/home/Hero.astro:ecxgf3">
          <span class="h-px w-8 bg-primary" data-ps="src/components/home/Hero.astro:z1i1xc"></span>
          <span class="text-sm font-bold tracking-widest uppercase text-primary" data-ps="src/components/home/Hero.astro:z1i1xb">Strategic Advisory</span>
          <span class="h-px w-8 bg-primary" data-ps="src/components/home/Hero.astro:z1i1xc"></span>
        </div>
        
        <h1 class="text-h1 font-bold mb-8 text-foreground leading-[1.05] reveal" data-ps="src/components/home/Hero.astro:p3vdzl">
           <span class="text-primary italic" data-ps="src/components/home/Hero.astro:z1i1xa">Security and Privacy, Engineered for Optimisation & Confidence</span> 
        </h1>
        
        <p class="text-xl md:text-2xl mb-12 max-w-2xl mx-auto text-muted-foreground leading-relaxed reveal reveal-delay-1" data-ps="src/components/home/Hero.astro:6uykn0">We transform structural risk into strategic advantage for the enterprise.</p>
        
        <div class="flex flex-wrap justify-center gap-4 reveal reveal-delay-2" data-ps="src/components/home/Hero.astro:ecxgf4">
          <a href="#solutions" class="px-8 py-4 bg-primary text-primary-foreground font-bold rounded-sm hover:bg-primary-hover transition-all hover-lift" data-ps="src/components/home/Hero.astro:8zc1z">
            Practice Areas
          </a>
          <a href="#accolades" class="px-8 py-4 border border-secondary text-secondary font-bold rounded-sm hover:bg-secondary hover:text-secondary-foreground transition-all" data-ps="src/components/home/Hero.astro:iblyyg">
            Industry Leadership
          </a>
          <a href="#contact" class="px-8 py-4 border border-secondary text-secondary font-bold rounded-sm hover:bg-secondary hover:text-secondary-foreground transition-all" data-ps="src/components/home/Hero.astro:8zc1y">
            Contact Advisory
          </a>
        </div>

        <!-- Diagnostic Micro-Ledger -->
        <div class="mt-16 grid grid-cols-2 md:grid-cols-3 gap-8 pt-8 w-full border-t border-border reveal reveal-delay-3" data-ps="src/components/home/Hero.astro:ecxgf5">
          <div data-ps="src/components/home/Hero.astro:ecxgf6">
            <span class="block text-xs font-bold uppercase tracking-widest text-muted-foreground mb-1" data-ps="src/components/home/Hero.astro:z1i1wo">Geographical coverage</span>
            <span class="block text-xl md:text-2xl font-bold text-foreground" data-ps="src/components/home/Hero.astro:z1i1wn">Asia-Pacific</span>
          </div>
          <div data-ps="src/components/home/Hero.astro:ecxgf7">
            <span class="block text-xs font-bold uppercase tracking-widest text-muted-foreground mb-1" data-ps="src/components/home/Hero.astro:z1i1wm">Compliance</span>
            <span class="block text-xl md:text-2xl font-bold text-foreground" data-ps="src/components/home/Hero.astro:z1i1wl">Cybersecurity, Privacy</span>
          </div>
          <div class="hidden md:block" data-ps="src/components/home/Hero.astro:ecxgf8">
            <span class="block text-xs font-bold uppercase tracking-widest text-muted-foreground mb-1" data-ps="src/components/home/Hero.astro:z1i1wk">Delivery</span>
            <span class="block text-xl md:text-2xl font-bold text-foreground" data-ps="src/components/home/Hero.astro:z1i1wj">Solutions + Services</span>
          </div>
        </div>
      </div>

      <!-- Image Block -->
      <div class="w-full relative h-[400px] md:h-[500px] lg:h-[650px] mt-8 rounded-sm overflow-hidden reveal-up border border-border" data-ps="src/components/home/Hero.astro:ecxgf9">
        <div class="absolute inset-0" data-ps="src/components/home/Hero.astro:ecxgfa">
          <div class="relative h-full w-full overflow-hidden" data-ps="src/components/home/Hero.astro:ecxgfb">
            <img 
              src="https://pagesmith-cdn.com/462bac59/images/change-the-text-on-the-laptop-screen-to-read-speoc-instead-o-65b6-1024.webp" 
              srcset="https://pagesmith-cdn.com/462bac59/images/change-the-text-on-the-laptop-screen-to-read-speoc-instead-o-65b6-1024.webp 1024w, https://pagesmith-cdn.com/462bac59/images/change-the-text-on-the-laptop-screen-to-read-speoc-instead-o-65b6-768.webp 768w, https://pagesmith-cdn.com/462bac59/images/change-the-text-on-the-laptop-screen-to-read-speoc-instead-o-65b6-640.webp 640w, https://pagesmith-cdn.com/462bac59/images/change-the-text-on-the-laptop-screen-to-read-speoc-instead-o-65b6-320.webp 320w"
              sizes="100vw"
              alt="Diverse executive consulting team with SPEOC displayed on laptop and glass partition" 
              class="h-full w-full object-cover object-center"
              loading="eager"
              fetchpriority="high" data-ps="src/components/home/Hero.astro:gfvoyz" />
            <div class="absolute inset-0 bg-secondary/10 mix-blend-multiply" data-ps="src/components/home/Hero.astro:ecxgfc"></div>
          </div>
        </div>
      </div>

    </div>
  </Container>
</section>