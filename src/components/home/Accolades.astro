---
import Container from '@/components/Container.astro';
---

<section id="accolades" class="py-24 bg-background border-t border-border" data-ps="src/components/home/Accolades.astro:uqm3cu">
  <Container>
    <div class="mb-16 reveal" data-ps="src/components/home/Accolades.astro:y5ylef">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-4" data-ps="src/components/home/Accolades.astro:rke4nf">Recognition & Authority</span>
      <h2 class="text-h2 font-bold text-foreground" data-ps="src/components/home/Accolades.astro:5lfwk3">Industry Leadership</h2>
    </div>

    <div class="divide-y divide-border border-y border-border" data-ps="src/components/home/Accolades.astro:y5yleg">
      <!-- Row 1 -->
      <div class="py-12 grid grid-cols-1 md:grid-cols-12 gap-8 items-center group reveal" data-ps="src/components/home/Accolades.astro:y5yleh">
        <div class="md:col-span-2" data-ps="src/components/home/Accolades.astro:y5ylei">
          <span class="text-sm font-bold tracking-widest uppercase text-primary" data-ps="src/components/home/Accolades.astro:rke4ng">Award</span>
        </div>
        <div class="md:col-span-7" data-ps="src/components/home/Accolades.astro:acreqa">
          <h3 class="text-2xl font-bold mb-2 group-hover:text-primary transition-colors" data-ps="src/components/home/Accolades.astro:k9utrq">Cyber Security Professional  Award</h3>
          <p class="text-muted-foreground" data-ps="src/components/home/Accolades.astro:i7b37c">Co-organized by the Hong Kong Police Force (CSTCB), the Digital Policy Office, and the Hong Kong Computer Emergency Response Team Coordination Centre (HKCERT)</p>
        </div>
        <div class="md:col-span-3 text-right" data-ps="src/components/home/Accolades.astro:acreq9">
          <span class="text-lg font-bold text-foreground font-display" data-ps="src/components/home/Accolades.astro:rke4nh">Individual</span>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="py-12 grid grid-cols-1 md:grid-cols-12 gap-8 items-center group reveal reveal-delay-1" data-ps="src/components/home/Accolades.astro:acreq8">
        <div class="md:col-span-2" data-ps="src/components/home/Accolades.astro:acreq7">
          <span class="text-sm font-bold tracking-widest uppercase text-primary" data-ps="src/components/home/Accolades.astro:rke4ni">leadership</span>
        </div>
        <div class="md:col-span-7" data-ps="src/components/home/Accolades.astro:acreq6">
          <h3 class="text-2xl font-bold mb-2 group-hover:text-primary transition-colors" data-ps="src/components/home/Accolades.astro:k9utrp">ISACA China Hong Kong Chapter</h3>
          <p class="text-muted-foreground" data-ps="src/components/home/Accolades.astro:i7b37d">ISACA® (www.isaca.org) is a global, not-for-profit community advancing individuals and organisations in their pursuit of digital trust. ISACA China Hong Kong Chapter is one of the largest chapters worldwide.</p>
        </div>
        <div class="md:col-span-3 text-right" data-ps="src/components/home/Accolades.astro:acreq5">
          <span class="text-lg font-bold text-foreground font-display" data-ps="src/components/home/Accolades.astro:rke4nj">CISA, CISM,
<br/>AAIA, AAISM</span>
        </div>
      </div>

      <!-- Row 3 -->
      <div class="py-12 grid grid-cols-1 md:grid-cols-12 gap-8 items-center group reveal reveal-delay-2" data-ps="src/components/home/Accolades.astro:acreq4">
        <div class="md:col-span-2" data-ps="src/components/home/Accolades.astro:acreq3">
          <span class="text-sm font-bold tracking-widest uppercase text-primary" data-ps="src/components/home/Accolades.astro:rke4nk">industry experience</span>
        </div>
        <div class="md:col-span-7" data-ps="src/components/home/Accolades.astro:acreq2">
          <h3 class="text-2xl font-bold mb-2 group-hover:text-primary transition-colors" data-ps="src/components/home/Accolades.astro:k9utro">Cybersecurity, Privacy, AI, Resiliency</h3>
          <p class="text-muted-foreground" data-ps="src/components/home/Accolades.astro:i7b37z">Over three decades of experience advising on cybersecurity, privacy, AI, cryptographic management, resiliency for clients across the private sector, privacy regulators, monetary authorities, research institutions, and NGOs.</p>
        </div>
        <div class="md:col-span-3 text-right" data-ps="src/components/home/Accolades.astro:acreq1">
          <span class="text-lg font-bold text-foreground font-display" data-ps="src/components/home/Accolades.astro:rke4nl">Specialist</span>
        </div>
      </div>
    </div>
  </Container>
</section>
